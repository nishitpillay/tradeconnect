# ─────────────────────────────────────────────────────────────
# TradeConnect Backend — Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://tc_user:tc_dev_password@localhost:5432/tradeconnect_dev
DB_SSL_ENABLED=false

# Pool settings (defaults shown)
DB_POOL_MAX=10
SLOW_QUERY_MS=300

# Encryption key for pgcrypto (exact_address_enc column on jobs table)
# Must be >= 32 chars. Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=change-me-to-a-32-char-random-string-minimum

# ── Auth / JWT ────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-64-char-random-secret-minimum-for-production-use
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ── Seeding ───────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@tradeconnect.com.au
# Must be >= 12 chars; required when running 02_admin_user seed
SEED_ADMIN_PASSWORD=ChangeMe123!
# Demo account password (dev/staging only)
SEED_DEMO_PASSWORD=DemoPass123!

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# For LocalStack (local dev): http://localhost:4566
# For production: leave S3_ENDPOINT unset (defaults to AWS)
S3_ENDPOINT=http://localhost:4566
S3_BUCKET_NAME=tradeconnect-media-dev
S3_PRESIGN_EXPIRY_SECONDS=3600
# CDN prefix for served media (CloudFront URL in prod)
CDN_BASE_URL=http://localhost:4566/tradeconnect-media-dev

# SES email (LocalStack or real SES)
SES_FROM_ADDRESS=noreply@tradeconnect.com.au
# SES_ENDPOINT=http://localhost:4566   # uncomment for LocalStack

# ── Firebase (Push Notifications) ────────────────────────────
FIREBASE_PROJECT_ID=tradeconnect-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tradeconnect-dev.iam.gserviceaccount.com
# Multi-line private key — wrap in double quotes, escape newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Google Maps ───────────────────────────────────────────────
# Restricted to: Maps JavaScript API, Places API, Geocoding API
# Australia country restriction applied at API level
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# BullMQ queue prefix
QUEUE_PREFIX=tc:

# ── Rate Limits (override defaults from constants/rate-limits.ts) ──
# All values: max count per window
RATE_LIMIT_JOB_POST_DAILY=3
RATE_LIMIT_JOB_POST_WEEKLY=10
RATE_LIMIT_QUOTE_DAILY=20
RATE_LIMIT_QUOTE_WEEKLY=100
RATE_LIMIT_MESSAGE_PER_HOUR=60
RATE_LIMIT_LOGIN_PER_15MIN=5

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=debug
# Sentry DSN (leave empty to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.0
OTEL_ENABLED=true
OTEL_SERVICE_NAME=tradeconnect-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
WORKER_CONCURRENCY=5
WORKER_METRICS_INTERVAL_MS=60000
WORKER_DLQ_ENABLED=true
NOTIFICATIONS_USE_QUEUE=true
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_BACKOFF_MS=1000
NOTIFICATION_DEDUPE_TTL_SECONDS=300

# ── Job Lifecycle ─────────────────────────────────────────────
JOB_EXPIRY_DAYS=30
QUOTE_EXPIRY_DAYS=14
REVIEW_WINDOW_DAYS=60
MESSAGE_RETENTION_MONTHS=24

# ── PII Detection ─────────────────────────────────────────────
PII_VIOLATIONS_BEFORE_FLAG=3
PII_VIOLATIONS_BEFORE_SUSPEND=5
