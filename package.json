{
  "name": "tradeconnect-main",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "turbo": "^2.1.3"
  },
  "pnpm": {
    "overrides": {
      "bullmq": "5.1.0",
      "ioredis": "5.3.2"
    }
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "smoke:all": "powershell -ExecutionPolicy Bypass -File scripts/smoke-all.ps1",
    "shared:build": "turbo run build --filter=@tradeconnect/shared",
    "backend:build": "turbo run build --filter=@tradeconnect/backend",
    "backend:openapi:generate": "turbo run openapi:generate --filter=@tradeconnect/backend",
    "backend:openapi:check": "turbo run openapi:check-drift --filter=@tradeconnect/backend",
    "backend:test": "turbo run test --filter=@tradeconnect/backend",
    "web:type-check": "turbo run typecheck --filter=tradeconnect-web",
    "web:build": "turbo run build --filter=tradeconnect-web",
    "web:verify": "turbo run verify --filter=tradeconnect-web",
    "mobile:type-check": "turbo run typecheck --filter=tradeconnect-mobile"
  }
}
