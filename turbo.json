{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "openapi/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "verify": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "openapi:generate": {
      "dependsOn": ["build"],
      "outputs": [
        "openapi/openapi.v1.json"
      ]
    },
    "openapi:check-drift": {
      "dependsOn": ["openapi:generate"],
      "outputs": []
    }
  }
}
