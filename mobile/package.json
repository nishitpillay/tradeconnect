{
  "name": "tradeconnect-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "node -e \"console.log('mobile build artifact is generated via EAS/Expo CI')\"",
    "test": "node -e \"console.log('mobile tests not configured')\"",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client --clear --port 8081",
    "android": "expo run:android",
    "android:smoke": "powershell -ExecutionPolicy Bypass -File scripts/android-smoke.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "node -e \"console.log('mobile lint not configured yet')\"",
    "typecheck": "tsc --noEmit",
    "type-check": "npm run typecheck"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/vector-icons": "^14.0.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tanstack/react-query": "^5.28.0",
    "@tradeconnect/shared": "workspace:*",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-dev-client": "~4.0.29",
    "expo-font": "~12.0.10",
    "expo-image-picker": "~15.1.0",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-location": "~17.0.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "nativewind": "^4.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-web": "~0.19.10",
    "socket.io-client": "^4.6.0",
    "zod": "^3.22.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@types/react": "~18.2.45",
    "eslint": "^8.57.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
